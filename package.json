{
    "name": "formj",
    "version": "0.0.0",
    "description": "A Preact library for creating forms based on a JSON Schema.",
    "bugs": "https://github.com/baltpeter/formj/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/baltpeter/formj.git"
    },
    "license": "MIT",
    "author": "Benjamin Altpeter <hi@bn.al>",
    "type": "module",
    "exports": {
        "types": "./dist/index.d.ts",
        "default": "./dist/formj.modern.js"
    },
    "module": "dist/formj.js",
    "source": "src/index.ts",
    "types": "dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "scripts": {
        "build": "microbundle",
        "fix": "yarn eslint . --ignore-path .gitignore --ext .js,.jsx,.ts,.tsx --fix",
        "lint": "tsc && eslint . --ignore-path .gitignore --ext .js,.jsx,.ts,.tsx && git diff --check",
        "prepack": "rm -rf dist && yarn build && yarn typedoc",
        "test": "echo 'TODO: No tests specified yet.'",
        "watch": "microbundle watch"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged && tsc && typedoc && git add docs"
        }
    },
    "lint-staged": {
        "*.{ts,js,tsx,jsx,css,scss,json}": [
            "prettier --write"
        ],
        "*.{ts,js,tsx,jsx}": [
            "eslint --fix"
        ]
    },
    "prettier": "@baltpeter/prettier-config",
    "dependencies": {
        "@segment/ajv-human-errors": "^2.11.0",
        "@udecode/zustood": "^2.0.0",
        "ajv": "^8.12.0",
        "classnames": "^2.3.2",
        "hash-it": "^6.0.0",
        "matcher": "^5.0.0",
        "scheduler": "^0.23.0",
        "zustand": "^4.3.9"
    },
    "devDependencies": {
        "@baltpeter/eslint-config": "^2.2.0",
        "@baltpeter/prettier-config": "2.0.0",
        "@baltpeter/tsconfig": "3.0.0",
        "@types/json-schema": "^7.0.12",
        "@typescript-eslint/eslint-plugin": "5.60.1",
        "eslint": "8.43.0",
        "eslint-plugin-eslint-comments": "3.2.0",
        "eslint-plugin-import": "2.27.5",
        "eslint-plugin-jsx-a11y": "^6.7.1",
        "eslint-plugin-react": "^7.33.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "husky": "4.3.7",
        "lint-staged": "13.2.3",
        "microbundle": "^0.15.1",
        "preact": "^10.15.1",
        "prettier": "2.8.8",
        "process": "^0.11.10",
        "typedoc": "0.24.8",
        "typedoc-plugin-markdown": "3.15.3",
        "typescript": "5.1.6"
    },
    "peerDependencies": {
        "preact": "^10.15.1"
    },
    "alias": {
        "react": "preact/compat",
        "react-dom/test-utils": "preact/test-utils",
        "react-dom": "preact/compat",
        "react/jsx-runtime": "preact/jsx-runtime"
    }
}
